<!-- ContractDetailDialog.fragment.xml
     Row-click drill-down dialog.
     Binds to model "contractDetail" (set in UiHelper.openContractDetail()).
     Sections:
       1. Header ObjectHeader  — BorrowerGroupName, Scheme, status
       2. Financial Summary    — Sanction / Disbursed / PrincipalOs CY vs PY
       3. Variance Analysis    — DisbursementVar, GrossSanctionVar, PrincipalOs delta
       4. Project Activity     — ProjectsCY, ProjectsPY, ProjectsVar%
-->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Dialog
        id="contractDetailDialog"
        title="Loan Group Detail"
        contentWidth="620px"
        contentHeight="auto"
        resizable="true"
        draggable="true"
        class="cmlDetailDialog">

        <customHeader>
            <Bar id="_IDGenBar">
                <contentLeft>
                    <Title id="_IDGenTitle3"
                        text="{contractDetail>/BorrowerGroupName}"
                        level="H4"/>
                </contentLeft>
                <contentMiddle>
                    <ObjectStatus id="_IDGenObjectStatus"
                        text="{contractDetail>/Scheme}"
                        state="Information"
                        icon="sap-icon://tag"/>
                </contentMiddle>
                <contentRight>
                    <Button id="_IDGenButton2"
                        icon="sap-icon://decline"
                        type="Transparent"
                        press=".onCloseContractDetail"
                        tooltip="Close"/>
                </contentRight>
            </Bar>
        </customHeader>

        <content>
            <VBox id="_IDGenVBox1" class="cmlDialogContent">

                <!-- ── Section 1 · Identifiers ─────────────────────────── -->
                <Title id="_IDGenTitle4" text="Identifiers" level="H5" class="cmlSectionTitle"/>
                <f:SimpleForm id="_IDGenSimpleForm"
                    editable="false"
                    layout="ResponsiveGridLayout"
                    labelSpanL="4" labelSpanM="4"
                    emptySpanL="0" emptySpanM="0"
                    columnsL="2" columnsM="2">
                    <f:content>
                        <Label id="_IDGenLabel3" text="Borrower Group ID"/>
                        <Text id="_IDGenText11" text="{contractDetail>/BorrowerGroup}"/>
                        <Label id="_IDGenLabel4" text="Borrower Name"/>
                        <Text id="_IDGenText12" text="{contractDetail>/BorrowerGroupName}"/>
                        <Label id="_IDGenLabel5" text="Scheme"/>
                        <Text id="_IDGenText13" text="{contractDetail>/Scheme}"/>
                    </f:content>
                </f:SimpleForm>

                <core:HTML id="_IDGenHTML1" content="&lt;hr class='cmlDivider'/&gt;"/>

                <!-- ── Section 2 · Financial Summary ─────────────────── -->
                <Title id="_IDGenTitle5" text="Financial Summary (₹ Cr)" level="H5" class="cmlSectionTitle"/>
                <f:SimpleForm id="_IDGenSimpleForm1"
                    editable="false"
                    layout="ResponsiveGridLayout"
                    labelSpanL="4" labelSpanM="4"
                    emptySpanL="0" emptySpanM="0"
                    columnsL="2" columnsM="2">
                    <f:content>

                        <Label id="_IDGenLabel6" text="Gross Sanction CY"/>
                        <ObjectNumber id="_IDGenObjectNumber3"
                            number="{path:'contractDetail>/GrossSanctionCY', formatter:'.fmt.crore'}"
                            unit="Cr"
                            state="{path:'contractDetail>/GrossSanctionCY', formatter:'.fmt.positiveState'}"/>

                        <Label id="_IDGenLabel7" text="Gross Sanction PY"/>
                        <ObjectNumber id="_IDGenObjectNumber4"
                            number="{path:'contractDetail>/GrossSanctionPY', formatter:'.fmt.crore'}"
                            unit="Cr"/>

                        <Label id="_IDGenLabel8" text="Disbursement CY"/>
                        <ObjectNumber id="_IDGenObjectNumber5"
                            number="{path:'contractDetail>/DisbursementCY', formatter:'.fmt.crore'}"
                            unit="Cr"
                            state="{path:'contractDetail>/DisbursementCY', formatter:'.fmt.positiveState'}"/>

                        <Label id="_IDGenLabel9" text="Disbursement PY"/>
                        <ObjectNumber id="_IDGenObjectNumber12"
                            number="{path:'contractDetail>/DisbursementPY', formatter:'.fmt.crore'}"
                            unit="Cr"/>

                        <Label id="_IDGenLabel10" text="Principal O/S CY"/>
                        <ObjectNumber id="_IDGenObjectNumber13"
                            number="{path:'contractDetail>/PrincipalOsCY', formatter:'.fmt.crore'}"
                            unit="Cr"
                            emphasized="true"/>

                        <Label id="_IDGenLabel11" text="Principal O/S PY"/>
                        <ObjectNumber id="_IDGenObjectNumber14"
                            number="{path:'contractDetail>/PrincipalOsPY', formatter:'.fmt.crore'}"
                            unit="Cr"/>

                    </f:content>
                </f:SimpleForm>

                <core:HTML id="_IDGenHTML2" content="&lt;hr class='cmlDivider'/&gt;"/>

                <!-- ── Section 3 · Variance Analysis ─────────────────── -->
                <Title id="_IDGenTitle6" text="Variance (CY vs PY)" level="H5" class="cmlSectionTitle"/>
                <f:SimpleForm id="_IDGenSimpleForm2"
                    editable="false"
                    layout="ResponsiveGridLayout"
                    labelSpanL="5" labelSpanM="5"
                    emptySpanL="0" emptySpanM="0"
                    columnsL="2" columnsM="2">
                    <f:content>

                        <Label id="_IDGenLabel12" text="Disbursement Δ"/>
                        <ObjectNumber id="_IDGenObjectNumber15"
                            number="{path:'contractDetail>/DisbursementVar', formatter:'.fmt.crore'}"
                            unit="Cr"
                            state="{path:'contractDetail>/DisbursementVar', formatter:'.fmt.varState'}"/>

                        <Label id="_IDGenLabel13" text="Disbursement Δ%"/>
                        <ObjectNumber id="_IDGenObjectNumber16"
                            number="{contractDetail>/DisbursementVarPct}"
                            unit="%"
                            state="{path:'contractDetail>/DisbursementVarPct', formatter:'.fmt.varState'}"/>

                        <Label id="_IDGenLabel14" text="Gross Sanction Δ"/>
                        <ObjectNumber id="_IDGenObjectNumber17"
                            number="{path:'contractDetail>/GrossSanctionVar', formatter:'.fmt.crore'}"
                            unit="Cr"
                            state="{path:'contractDetail>/GrossSanctionVar', formatter:'.fmt.varState'}"/>

                        <Label id="_IDGenLabel15" text="Projects Δ"/>
                        <ObjectNumber id="_IDGenObjectNumber18"
                            number="{contractDetail>/ProjectsVar}"
                            state="{path:'contractDetail>/ProjectsVar', formatter:'.fmt.varState'}"/>

                        <Label id="_IDGenLabel16" text="Projects Δ%"/>
                        <ObjectNumber id="_IDGenObjectNumber19"
                            number="{contractDetail>/ProjectsVarPct}"
                            unit="%"
                            state="{path:'contractDetail>/ProjectsVarPct', formatter:'.fmt.varState'}"/>

                    </f:content>
                </f:SimpleForm>

                <core:HTML id="_IDGenHTML3" content="&lt;hr class='cmlDivider'/&gt;"/>

                <!-- ── Section 4 · Project Activity ───────────────────── -->
                <Title id="_IDGenTitle7" text="Project Activity" level="H5" class="cmlSectionTitle"/>
                <f:SimpleForm id="_IDGenSimpleForm3"
                    editable="false"
                    layout="ResponsiveGridLayout"
                    labelSpanL="4" labelSpanM="4"
                    emptySpanL="0" emptySpanM="0"
                    columnsL="2" columnsM="2">
                    <f:content>
                        <Label id="_IDGenLabel17" text="Active Projects CY"/>
                        <ObjectNumber id="_IDGenObjectNumber20" number="{contractDetail>/ProjectsCY}"/>
                        <Label id="_IDGenLabel18" text="Active Projects PY"/>
                        <ObjectNumber id="_IDGenObjectNumber21" number="{contractDetail>/ProjectsPY}"/>
                        <Label id="_IDGenLabel19" text="Net Project Cost CY (₹ Cr)"/>
                        <ObjectNumber id="_IDGenObjectNumber22"
                            number="{path:'contractDetail>/ProjectCostCY', formatter:'.fmt.crore'}"
                            unit="Cr"/>
                    </f:content>
                </f:SimpleForm>

            </VBox>
        </content>

        <buttons>
            <Button id="_IDGenButton3"
                text="Export Row"
                type="Transparent"
                icon="sap-icon://download"
                press=".onExportContractRow"/>
            <Button id="_IDGenButton4"
                text="Close"
                type="Emphasized"
                press=".onCloseContractDetail"/>
        </buttons>

    </Dialog>

</core:FragmentDefinition>
